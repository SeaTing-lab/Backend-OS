// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ──────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  fcmToken     String?  // Firebase push token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  thresholds   AlertThreshold?
  alerts       Alert[]
}

// ── Sensor readings (time-series) ─────────────────────────────────────────
model SensorReading {
  id          Int      @id @default(autoincrement())
  temperature Float
  humidity    Float    @default(0)
  gasLevel    Int
  isRaining   Boolean  @default(false)
  distance    Float    // ultrasonic cm
  doorOpen    Boolean  @default(false)
  rawPayload  String?  // original JSON from ESP32
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model PowerReading {
  id              String   @id @default(cuid())
  identityKey     String   @unique
  deviceId        String   @default("power_point_1")
  voltage         Float
  current         Float
  powerFactor     Float    @default(1)
  cableResistance Float    @default(0.05)
  power           Float
  powerLoss       Float
  energyKwh       Float    @default(0)
  source          String   @default("unknown")
  rawPayload      String?
  timestamp       DateTime
  createdAt       DateTime @default(now())

  @@index([timestamp])
  @@index([deviceId, timestamp])
}

model EnergyPriceRule {
  id            Int      @id @default(autoincrement())
  effectiveDate DateTime @unique
  unitPrice     Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([effectiveDate])
}

// ── Device state ──────────────────────────────────────────────────────────
model Device {
  id          String   @id  // "relay_1", "relay_2", "buzzer", etc.
  name        String
  type        String   // "relay" | "actuator"
  icon        String
  channel     String   // MQTT topic
  isOn        Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

// ── Control mode ──────────────────────────────────────────────────────────
model SystemState {
  id          Int      @id @default(1)
  mode        String   @default("manual") // "manual" | "automatic" | "google"
  esp32Online Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

// ── Alert thresholds per user ─────────────────────────────────────────────
model AlertThreshold {
  id              Int    @id @default(autoincrement())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id])
  temperatureMax  Float  @default(35)
  gasLevelMax     Int    @default(300)
  ultrasonicMin   Float  @default(100)
}

// ── Alert / notification history ──────────────────────────────────────────
model Alert {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  type        String   // "temperature" | "gas" | "door" | "motion" | "rain"
  severity    String   // "info" | "warning" | "danger"
  title       String
  description String
  value       Float?   // the reading that triggered the alert
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Photo {
  id            String   @id
  filename      String?
  mimeType      String
  size          Int
  imageBase64   String
  timestamp     DateTime
  distanceCm    Float    @default(0)
  thresholdCm   Float    @default(0)
  source        String   @default("ultrasonic")
  cameraSource  String   @default("phone")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([timestamp])
  @@index([createdAt])
}

